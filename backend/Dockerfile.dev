FROM node:20-alpine
WORKDIR /app
# Install deps first (cached layer), then bind-mount overwrites src only
COPY package*.json ./
RUN npm install
# nodemon for hot-reload
RUN npm install -g nodemon
EXPOSE 5101
CMD ["nodemon", "--watch", ".", "--ext", "js,mjs,json", "--ignore", "node_modules", "index.js"]
