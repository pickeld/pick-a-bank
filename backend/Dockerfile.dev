FROM node:20-bookworm-slim

# All dependencies Firefox needs (including libasound2 → libasound2-dev on bookworm)
RUN apt-get update && apt-get install -y --no-install-recommends \
    wget curl ca-certificates fonts-liberation fonts-noto-cjk \
    libatk-bridge2.0-0 libatk1.0-0 libcairo2 libcups2 libdbus-1-3 \
    libdrm2 libgbm1 libglib2.0-0 libgtk-3-0 libnspr4 libnss3 \
    libpango-1.0-0 libx11-6 libxcb1 libxcomposite1 libxdamage1 \
    libxext6 libxfixes3 libxrandr2 libxrender1 libxshmfence1 \
    libxt6 libxv1 xvfb dbus-x11 \
    libasound2 libpulse0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY package*.json ./
RUN npm install
RUN npm install -g nodemon

# Install Playwright's Firefox (runs in-container, not skipped)
ENV PLAYWRIGHT_BROWSERS_PATH=/app/pw-browsers
RUN npx playwright install firefox

# Disable Firefox content sandbox — required when running without SYS_ADMIN
ENV MOZ_DISABLE_CONTENT_SANDBOX=1

EXPOSE 5101
CMD ["nodemon", "--watch", ".", "--ext", "js,mjs,json", \
     "--ignore", "node_modules", \
     "--ignore", "pw-browsers", \
     "--ignore", "scraper/.isracard-cookies.json", \
     "--ignore", "scraper/.discount-cookies.json", \
     "index.js"]
